# OpenAI API Key (required — embeddings and LLM both use OpenAI)
OPENAI_API_KEY=your-openai-api-key-here

# Ollama Configuration (required if using Ollama provider)
# Make sure Ollama is running on this address
# To check the available models, run: curl http://localhost:11434/v1/models
OLLAMA_BASE_URL=http://localhost:11434

# JWT Secret Key — used to sign access tokens for the REST API.
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-strong-random-secret

# PostgreSQL / RDS Database Configuration
# For local dev: use localhost. For AWS: use the RDS endpoint.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=poc2prod
DB_USER=your-db-username-here
DB_PASSWORD=your-db-password-here

# ── Cloud deployment (AWS) ────────────────────────────────────────────────────
# Only required when configs/config.yaml has storage.deployment = cloud

# S3 — bucket where uploaded documents are stored
AWS_S3_BUCKET=your-s3-bucket-name
AWS_S3_REGION=us-east-1

# Redis (ElastiCache) — LangGraph checkpointer + pending clarifications store
# Format: redis://hostname:6379  or  redis://username:password@hostname:6379
REDIS_URL=redis://your-elasticache-endpoint:6379

# AWS credentials — not needed if running on EC2/ECS with an IAM role attached.
# Only set these for local development pointing at real AWS resources.
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key

# MCP server
MCP_SERVER_NAME=mcp-tools-library
MCP_TRANSPORT=streamable-http
MCP_SERVER_URL=http://host.docker.internal:8001/mcp

# Stateless utility tools
TAVILY_API_KEY=tavily-api-key-here

# RaV-IDP integration
RAV_IDP_MODE=full
RAV_IDP_OUTPUT_DIR=.mcp-data/rav-idp

# Data analysis tool
E2B_API_KEY=e2b-api-key-here
E2B_ANALYSIS_TIMEOUT_SECONDS=300
ADMIN_EMAILS=user1@example.com,user2@example.com

# Scheduler
# Production/EKS must leave this false. Set true only for local development.
ENABLE_IN_PROCESS_SCHEDULER=false

# Job safety
JOB_DRY_RUN=false
JOB_BATCH_SIZE=100
